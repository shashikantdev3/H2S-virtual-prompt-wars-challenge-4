# Copy to .env and fill in. NEVER commit your real .env.
# The app runs fully without a key using a deterministic fallback,
# but a key enables richer, generative multilingual responses.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Port the server listens on (Cloud Run injects PORT automatically)
PORT=8080
